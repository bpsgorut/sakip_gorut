# ===== KONFIGURASI EMAIL UNTUK RESET PASSWORD =====
# Salin pengaturan ini ke file .env Anda dan sesuaikan dengan provider email yang digunakan

# Untuk Gmail SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="SAKIP BPS"

# Untuk Outlook/Hotmail SMTP
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@outlook.com
# MAIL_PASSWORD=your-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=your-email@outlook.com
# MAIL_FROM_NAME="SAKIP BPS"

# Untuk Yahoo SMTP
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mail.yahoo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@yahoo.com
# MAIL_PASSWORD=your-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=your-email@yahoo.com
# MAIL_FROM_NAME="SAKIP BPS"

# Untuk testing (email akan disimpan di log file)
# MAIL_MAILER=log
# MAIL_FROM_ADDRESS=noreply@sakip-bps.go.id
# MAIL_FROM_NAME="SAKIP BPS"

# ===== CATATAN PENTING =====
# 1. Untuk Gmail, gunakan App Password bukan password biasa
# 2. Aktifkan 2-Factor Authentication di Gmail terlebih dahulu
# 3. Generate App Password di: https://myaccount.google.com/apppasswords
# 4. Untuk production, gunakan email server resmi BPS
# 5. Pastikan firewall tidak memblokir port SMTP (587/465)

# ===== PENGATURAN QUEUE (OPSIONAL) =====
# Untuk mengirim email secara asynchronous (tidak memblokir request)
# QUEUE_CONNECTION=database
# Jangan lupa jalankan: php artisan queue:work